        "team_sets_completeness_valid": {
          "name": "team_sets_completeness_valid",
          "value": "\"team_sets\".\"completeness\" IN ('minimal','partial','full')"
        },
        "team_sets_source_site_pokepaste": {
          "name": "team_sets_source_site_pokepaste",
          "value": "\"team_sets\".\"source_site\" = 'pokepaste'"
        },
        "team_sets_level_range": {
          "name": "team_sets_level_range",
          "value": "\"team_sets\".\"level\" IS NULL OR (\"team_sets\".\"level\" BETWEEN 1 AND 100)"
        },
        "team_sets_moves_len": {
          "name": "team_sets_moves_len",
          "value": "json_array_length(\"team_sets\".\"moves_json\") BETWEEN 0 AND 4"
        },
        "team_sets_sps_total_le_66": {
          "name": "team_sets_sps_total_le_66",
          "value": "\"team_sets\".\"sps_json\" IS NULL OR\n          (json_extract(\"team_sets\".\"sps_json\",'$.hp')+json_extract(\"team_sets\".\"sps_json\",'$.atk')\n          +json_extract(\"team_sets\".\"sps_json\",'$.def')+json_extract(\"team_sets\".\"sps_json\",'$.spa')\n          +json_extract(\"team_sets\".\"sps_json\",'$.spd')+json_extract(\"team_sets\".\"sps_json\",'$.spe')) <= 66"
        },
        "team_sets_sps_per_stat_le_32": {
          "name": "team_sets_sps_per_stat_le_32",
          "value": "\"team_sets\".\"sps_json\" IS NULL OR (\n        json_extract(\"team_sets\".\"sps_json\",'$.hp')  <= 32 AND\n        json_extract(\"team_sets\".\"sps_json\",'$.atk') <= 32 AND\n        json_extract(\"team_sets\".\"sps_json\",'$.def') <= 32 AND\n        json_extract(\"team_sets\".\"sps_json\",'$.spa') <= 32 AND\n        json_extract(\"team_sets\".\"sps_json\",'$.spd') <= 32 AND\n        json_extract(\"team_sets\".\"sps_json\",'$.spe') <= 32\n      )"
        }
      }
